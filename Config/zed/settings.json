// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "text_rendering_mode": "platform_default",
  "languages": {
    "Diff": {
      "inlay_hints": {
        "enabled": true,
      },
    },
  },
  "sticky_scroll": {
    "enabled": false,
  },
  "soft_wrap": "editor_width",
  "notification_panel": {
    "button": false,
    "dock": "left",
  },
  "edit_predictions": {
    "mode": "subtle",
    "copilot": {
      "enable_next_edit_suggestions": true,
    },
    "provider": "copilot",
  },
  "ui_font_weight": 400.0,
  "minimap": {
    "thumb": "always",
  },
  "colorize_brackets": true,
  "inlay_hints": {
    "enabled": false,
  },
  "tab_size": 2,
  "vim": {
    "use_system_clipboard": "on_yank",
    "toggle_relative_line_numbers": false,
  },
  "toolbar": {
    "selections_menu": false,
    "agent_review": false,
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "which_key": {
    "enabled": false,
  },
  "debugger": {
    "button": false,
  },
  "diagnostics": {
    "button": false,
  },
  "search": {
    "button": false,
  },
  "preview_tabs": {
    "enable_preview_file_from_code_navigation": true,
    "enable_preview_from_project_panel": true,
  },
  "centered_layout": {
    "left_padding": 0.15,
  },
  "tabs": {
    "show_close_button": "hover",
    "show_diagnostics": "off",
    "close_position": "right",
    "file_icons": true,
    "git_status": false,
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
    "show": true,
  },
  "terminal": {
    "blinking": "on",
    "cursor_shape": "underline",
    "button": false,
  },
  "status_bar": {
    "cursor_position_button": false,
    "active_language_button": false,
    "experimental.show": true,
  },
  "project_panel": {
    "button": false,
    "hide_root": true,
  },
  "rounded_selection": false,
  "current_line_highlight": "all",
  "agent_buffer_font_size": 17.0,
  "title_bar": {
    "show_branch_name": false,
    "show_menus": false,
    "show_user_menu": true,
    "show_user_picture": false,
    "show_project_items": false,
    "show_onboarding_banner": false,
    "show_branch_icon": false,
    "show_sign_in": false,
  },
  "agent": {
    "show_turn_stats": true,
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
    },
    "dock": "right",
    "favorite_models": [],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
    },
    "model_parameters": [],
  },
  "ui_font_family": "JetBrains Mono",
  "buffer_line_height": "comfortable",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "session": {
    "trust_all_worktrees": true,
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "diagnostics": true,
    "metrics": true,
  },
  "vim_mode": true,
  "icon_theme": "Base Charmed Icons",
  "ui_font_size": 18.0,
  "buffer_font_size": 17.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Tokyo Night",
  },
  "theme_overrides": {
    "Tokyo Night": {
      "border.variant": "#1A1B26",
      "border": "#1A1B26",
      "panel.background": "#1A1B26",
      "panel.focused_border": "#414868",
      "tab_bar.background": "#1A1B26",
      "tab.active_background": "#1A1B26",
      "tab.inactive_background": "#1A1B26",
      "status_bar.background": "#1A1B26",
      "title_bar.background": "#1A1B26",
      "scrollbar.thumb.border": "#1A1B26",
      "scrollbar.thumb.background": "#1A1B26",
      "scrollbar.track.border": "#1A1B26",
    },
  },
}
