max-history=100
sort=-time

font=JetBrainsMono Nerd Font 11
width=400
height=100
margin=15
padding=15
border-size=1
border-radius=0
background-color=#1a1b26
text-color=#c0caf5
border-color=#c0caf5

icons=1
max-icon-size=64
icon-location=left
format=<b>%s</b>\n%b

progress-color=over #44475a 

layer=overlay
anchor=top-right

# Notifications disappear after 5 seconds
default-timeout=5000 
ignore-timeout=0


# Volume OSD
[app-name="Volume"]
default-timeout=1500
group-by=app-name

# Music Player Album Art
[app-name="MusicPlayer"]
max-icon-size=96
default-timeout=5000
group-by=app-name
